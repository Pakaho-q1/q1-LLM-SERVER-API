{
    "ignore_patterns": [
        "__pycache__/",
        "backup/",
        "data/",
        "git_upload/",
        "models/",
        "*.log",
        "temp/",
        "*.bat",
        ".env",
        ".git/",
        "*.pyc",
        ".DS_Store",
        "node_modules/",
        "venv/",
        ".gitignore",
        ".github/",
        ".vscode/",
        ".idea/",
        "upload_to_github.py",
        "git-upload-config.json",
        "env/"
    ],
    "default_branch": "main",
    "remote_name": "origin",
    "large_file_limit_mb": 100,
    "ask_for_message": true,
    "auto_commit_message": "Auto commit on {date}"
}